.43],[146.73999999999998,-36.42499999999998],[146.7375,-36.41250000000001],[146.73499999999999,-36.41250000000001],[146.7375,-36.39999999999999],[146.74500000000003,-36.39500000000001],[146.75,-36.3675],[146.755,-36.36249999999999],[146.7525,-36.34749999999999],[146.765,-36.337500000000006],[146.7675,-36.32000000000001],[146.78,-36.3125],[146.78249999999997,-36.305],[146.795,-36.3025],[146.795,-36.30000000000001],[146.8075,-36.30000000000001],[146.805,-36.2875],[146.79749999999999,-36.2825],[146.8,-36.27],[146.81,-36.267500000000005],[146.81,-36.27],[146.81750000000002,-36.27],[146.81750000000002,-36.2725],[146.8225,-36.2725],[146.8275,-36.2775],[146.83000000000004,-36.2725],[146.8425,-36.2725],[146.8475,-36.267500000000005],[146.85,-36.2525],[146.8425,-36.25],[146.8425,-36.2525],[146.83000000000004,-36.2525],[146.82499999999996,-36.245000000000005],[146.82,-36.245000000000005],[146.81750000000002,-36.23749999999999],[146.8225,-36.23250000000001],[146.82,-36.23250000000001],[146.82,-36.2275],[146.8125,-36.225],[146.815,-36.21999999999999],[146.81,-36.217499999999994],[146.82499999999996,-36.2025],[146.82499999999996,-36.197500000000005],[146.83250000000004,-36.19499999999999],[146.83250000000004,-36.197500000000005],[146.8575,-36.2],[146.86,-36.19499999999999],[146.8675,-36.19499999999999],[146.8675,-36.1875],[146.8825,-36.1775],[146.89,-36.15999999999999],[146.895,-36.15999999999999],[146.89750000000004,-36.155],[146.9075,-36.157499999999985],[146.9075,-36.152499999999996],[146.91249999999997,-36.14999999999999],[146.91249999999997,-36.1425],[146.92249999999999,-36.1325],[146.9375,-36.1325],[146.94,-36.12749999999999],[146.94500000000002,-36.12749999999999],[146.95,-36.122499999999995],[146.94750000000002,-36.1125],[146.95,-36.115],[146.9725,-36.115],[146.96999999999997,-36.11000000000001],[146.9725,-36.1075],[146.98,-36.1075],[146.98500000000004,-36.10000000000001],[146.99499999999998,-36.10000000000001]]]}]},"properties":{"feedType":"warning","cap":{"category":"Met","event":"Riverine Flood","eventCode":"riverineflod","urgency":"Expected","severity":"Minor","certainty":"Unknown","contact":"john.newlands@ses.vic.gov.au","senderName":"State Emergency Service","responseType":"Monitor"},"sourceOrg":"EMV","sourceId":"42012","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"42012","category1":"Advice","category2":"Met","status":"Minor","name":"Advice","action":"Stay Informed","statewide":"N","location":"the kiewa River at Bandiana","created":"2026-06-20T18:04:19+10:00","updated":"2026-06-20T18:04:20+10:00","webHeadline":null,"webBody":"<div style=\"margin-bottom:20px\">This&nbsp;<b>Minor Flood Warning </b>is being issued<b>&nbsp;</b>for <span class=\"editable editable-click editable-unsaved\" data-type=\"text\" data-emptytext=\"[sub-catchment]\" data-value=\"the kiewa River at Bandiana\" contenteditable=\"false\" style=\"display: inline;\" data-original-title=\"\" title=\"\">the kiewa River at Bandiana</span>.<div><div><br></div></div><div><b>Initial Minor Flood Warning for the Kiewa River&nbsp; &nbsp;&nbsp;</b></div><div><br></div><div>MINOR FLOODING POSSIBLE AT BANDIANA FROM SATURDAY EVENING\n\n&nbsp;&nbsp;</div><div><br></div><div>Moderate rainfall across the Kiewa River catchment since\nThursday afternoon has caused river level rises along the Kiewa River. Minor\nflooding is likely at Bandiana from Saturday evening as flows arrive from\nupstream.\n\n&nbsp;&nbsp;</div><div><br></div><div>Showers are forecast across the catchment for the\nremainder of Saturday but will ease into Sunday.\n\n&nbsp;&nbsp;</div><div><br></div><div><b>Kiewa River downstream of Mongans Bridge:&nbsp;</b></div><div><b><br></b></div><div>Minor flooding is likely to develop along the Kiewa River\nat <b>Bandiana</b>.\n\n&nbsp;&nbsp;</div><div><br></div><div>The Kiewa River at Bandiana is currently at 2.70 m and\nrising slowly, below the minor flood level (2.80 m). The Kiewa River at\nBandiana is likely to exceed the minor flood level Saturday evening and the\nriver may remain above the minor flood level (2.80 m) throughout Sunday and\ninto Monday morning.</div><div><br></div></div><div style=\"font-size: 120%; font-weight: bold; margin-bottom:20px\">Stay informed - monitor your\nlocal conditions and remain alert. </div><div style=\"margin-bottom:20px\"><b>What you should do:&nbsp;</b><div><div><ul><li>Be prepared to act if your situation changes.</li><li>Stay informed by listening to emergency\nbroadcasters and monitoring warnings. </li><li>Floodwater is dangerous - never drive, walk or ride through floodwater.</li><li>Farmers should consider moving livestock and machinery to higher ground.</li><li>Floodwater is toxic - never play or swim in floodwater.</li></ul></div></div></div><div style=\"margin-bottom:20px\"><b>Impacts in your area:&nbsp;</b><div><div><ul><li>High river levels and potential flooding in areas close to rivers and streams.</li><li>Local roads may be closed and low bridges may be underwater.</li><li>Caravan parks and camping grounds may be flooded.</li><li>The Wayside Stop at Bandiana maybe affected by flood waters.</li></ul></div></div></div><div style=\"margin-bottom:20px\">This message was issued\nby <span title=\"warning_issuing_agency\" class=\"param\" contenteditable=\"false\">State Emergency Service</span>.<div><br></div><div><b>The\nnext update is expected by <span title=\"warning_next_update\" class=\"param\" contenteditable=\"false\">22/06/2026 12:00 pm</span>&nbsp;or as the situation changes.</b></div><div><br></div><div><div><b>Use multiple sources to stay informed:</b></div></div><div><ul><li><a href=\"http://emergency.vic.gov.au/respond/\" title=\"\" target=\"_blank\">www.emergency.vic.gov.au</a></li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/115001055007-What-is-the-VicEmergency-Hotline-\" title=\"\" target=\"_blank\">VicEmergency Hotline</a>&nbsp;- freecall 1800 226 226</li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/230492607-What-is-the-VicEmergency-app-a\" title=\"\" target=\"_blank\">VicEmergency app</a></li><li><a href=\"https://facebook.com/vicemergency\" title=\"\" target=\"_blank\">Facebook</a> or <a href=\"https://twitter.com/vicemergency\" title=\"\" target=\"_blank\">Twitter</a> (#vicfloods)</li><li>Tune in to ABC Local Radio, commercial and designated community radio stations, or Sky News TV.</li></ul></div><div><b>Accessibility:&nbsp;</b></div><div>The following services can help you, or someone you know, access information during an emergency.&nbsp; </div><div><ul><li>To access this information in other languages call the <a href=\"https://www.tisnational.gov.au/\" title=\"\" target=\"_blank\">Translating and Interpreting Service</a> on 131 450 (freecall) and ask them to call VicEmergency Hotline.&nbsp;</li><li>If you are deaf, hard of hearing, or have a speech/communication impairment contact the&nbsp;<a href=\"https://www.accesshub.gov.au/about-the-nrs\" title=\"\" target=\"_blank\">National Relay Service</a>&nbsp;and ask them to call the VicEmergency Hotline.&nbsp;&nbsp;</li></ul></div></div>","text":"ADVICE - RIVERINE FLOOD - Stay Informed\nIncident Location: the kiewa River at Bandiana\nIssue Date: Saturday 20 June 2026, 06:04 pm\nNext Update: Monday 22 June 2026, 12:00 pm\n\nMore details at http://emergency.vic.gov.au/respond/#!/warning/42012/moreinfo\n\nThis Minor Flood Warning is being issued for the kiewa River at Bandiana.\n\nInitial Minor Flood Warning for the Kiewa River    \n\nMINOR FLOODING POSSIBLE AT BANDIANA FROM SATURDAY EVENING    \n\nModerate rainfall across the Kiewa River catchment since Thursday afternoon has caused river level rises along the Kiewa River. Minor flooding is likely at Bandiana from Saturday evening as flows arrive from upstream.    \n\nShowers are forecast across the catchment for the remainder of Saturday but will ease into Sunday.    \n\nKiewa River downstream of Mongans Bridge: \n\nMinor flooding is likely to develop along the Kiewa River at Bandiana.    \n\nThe Kiewa River at Bandiana is currently at 2.70 m and rising slowly, below the minor flood level (2.80 m). The Kiewa River at Bandiana is likely to exceed the minor flood level Saturday evening and the river may remain above the minor flood level (2.80 m) throughout Sunday and into Monday morning.\n\n\nStay informed - monitor your local conditions and remain alert. \n\n","sizeFmt":null,"incidentFeatures":[{"properties":{"feedType":"incident","sourceOrg":"EMV","sourceId":"42012","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"42012","category1":"Met","category2":"Riverine Flood","name":"Advice","location":"the kiewa River at Bandiana","created":"2026-06-20T18:04:19+10:00","updated":"2026-06-20T18:04:20+10:00","webHeadline":null,"sizeFmt":null}}]}},{"type":"Feature","geometry":{"type":"GeometryCollection","geometries":[{"type":"Point","coordinates":[144.2751023968582,-38.37612848525832]},{"type":"Polygon","coordinates":[[[144.25312974058832,-38.39545671985721],[144.2523572643903,-38.393573158386545],[144.25312974058832,-38.393169531687654],[144.252700587143,-38.391756820498365],[144.25124146543962,-38.3910168179077],[144.2507264813106,-38.38738396808142],[144.25347306334098,-38.384491012702725],[144.2590520580854,-38.381126965595705],[144.26609017454214,-38.379781302947414],[144.27089669309754,-38.37493671015001],[144.2796514233266,-38.37184138380587],[144.28145386778266,-38.369688035211446],[144.28437211118936,-38.368072981715834],[144.28832032286306,-38.36120860226776],[144.2908952435171,-38.359997173612285],[144.29364182559237,-38.35898763424682],[144.29402806368688,-38.35784347261371],[144.2947147092012,-38.35757425548352],[144.2955730160829,-38.35757425548352],[144.29647423830644,-38.35680025065943],[144.29947831240577,-38.358651117996324],[144.28814866148673,-38.36928427521653],[144.25312974058832,-38.39545671985721]]]}]},"properties":{"feedType":"warning","cap":{"category":"Env","event":"Dangerous Animal","eventCode":"animalDanger","urgency":"Expected","severity":"Minor","certainty":"Unknown","contact":"lily.watson-jones@justice.vic.gov.au","senderName":"Other Agencies","responseType":"Monitor"},"sourceOrg":"EMV","sourceId":"42015","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"42015","category1":"Advice","category2":"Env","status":"Minor","name":"Advice","action":"Avoid the Area","statewide":"N","location":"Bells Beach","created":"2026-06-21T17:25:38+10:00","updated":"2026-06-21T17:25:39+10:00","webHeadline":null,"webBody":"<div style=\"margin-bottom:20px\">This <b>Advice </b>message is being issued for&nbsp;<span title=\"warning_locality\" class=\"param\" contenteditable=\"false\">Bells Beach</span>.<div><div><div><ul><li>This replaces the Advice issued at 4:40pm.&nbsp;</li><li>To reduce the threat to people, Bells Beach and Winkipop are closed.</li><li>Due to a <span class=\"editable editable-click editable-unsaved\" data-type=\"select\" data-emptytext=\"[whale carcass / whale stranding]\" data-value=\"0\" contenteditable=\"false\" style=\"display: inline;\" data-source=\"{&quot;0&quot;:&quot;whale carcass&quot;,&quot;1&quot;:&quot;whale stranding&quot;}\" data-original-title=\"\" title=\"\">whale carcass</span>&nbsp;there <span class=\"editable editable-click editable-unsaved\" data-type=\"select\" data-emptytext=\"[has been/could be]\" data-value=\"1\" contenteditable=\"false\" style=\"display: inline;\" data-source=\"{&quot;0&quot;:&quot;has been&quot;,&quot;1&quot;:&quot;could be&quot;}\" data-original-title=\"\" title=\"\">could be</span>&nbsp;an increase in shark activity at <span class=\"editable editable-click editable-unsaved\" data-type=\"text\" data-emptytext=\"[location]\" data-value=\"Bells Beach\" contenteditable=\"false\" style=\"display: inline;\" data-original-title=\"\" title=\"\">Bells Beach</span>&nbsp;and Winkipop.</li><li>A&nbsp;<span class=\"editable editable-click editable-unsaved\" data-type=\"select\" data-emptytext=\"[whale carcass / whale stranding]\" data-value=\"0\" contenteditable=\"false\" style=\"display: inline;\" data-source=\"{&quot;0&quot;:&quot;whale carcass&quot;,&quot;1&quot;:&quot;whale stranding&quot;}\" data-original-title=\"\" title=\"\">whale carcass</span>&nbsp;can attract sharks\nto the area and mean they are closer to the shore than normal.</li><li>While it is not uncommon for sharks to be\npresent off the Victorian coast, you should exercise additional caution in the\narea. </li></ul></div></div></div></div><div style=\"font-size: 120%; font-weight: bold; margin-bottom:20px\">Avoid the area. Stay informed and do not enter the water at closed beaches. </div><div style=\"margin-bottom:20px\"><b>What you should do:</b><div><div><ul><li>If you see sharks, report the sighting by calling Triple Zero (000) or notify lifesavers immediately if you are at a patrolled beach.</li></ul></div><div><b>Staying safe at nearby beaches:<br></b></div><div><ul><li>Always swim, dive or surf\nwith a friend.</li><li>Swim between the red and\nyellow flags on patrolled beaches.</li><li>Don't swim in places where\nhuman or animal waste enters the water.</li><li>Keep away from large schools of\nfish, seals or other wildlife as these can attract sharks. </li></ul></div></div></div><div style=\"margin-bottom:20px\"><b>Impacts in your area:</b>&nbsp;<div><ul><li>The Victorian Fisheries Authority is monitoring for shark sightings and providing advice to relevant authorities.</li><li>No public access to Bells Beach and Winkipop.&nbsp;</li></ul></div></div><div style=\"margin-bottom:20px\">This message was issued by <span title=\"warning_issuing_agency\" class=\"param\" contenteditable=\"false\">Victorian Fisheries Authority</span>.<div><br></div><div><b>The next update is\nexpected by </b><span title=\"warning_next_update\" class=\"param\" contenteditable=\"false\">22/06/2026 02:20 pm</span><b>&nbsp;or as the situation changes.</b></div><div><br></div><div><b>Use multiple sources to stay\ninformed:&nbsp;</b></div><div><ul><li><a href=\"https://emergency.vic.gov.au/respond/\" title=\"\" target=\"_blank\">www.emergency.vic.gov.au</a>&nbsp;</li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/115001055007-What-is-the-VicEmergency-Hotline-\" title=\"\" target=\"_blank\">VicEmergency Hotline</a>&nbsp;- freecall 1800 226 226&nbsp;</li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/230492607-What-is-the-VicEmergency-app-a\" title=\"\" target=\"_blank\">VicEmergency app</a>&nbsp;</li><li><a href=\"https://www.facebook.com/vicemergency\" title=\"\" target=\"_blank\">Facebook</a>\nor&nbsp;<a href=\"https://twitter.com/vicemergency\" title=\"\" target=\"_blank\">Twitter</a>&nbsp;</li><li>Tune in to ABC Local Radio,\ncommercial and designated community radio stations, or Sky News TV.\n\n&nbsp;</li><li>For more information on staying safe around sharks, visit <a href=\"http://www.vfa.vic.gov.au/shark-smart\" title=\"\" target=\"_blank\">www.vfa.vic.gov.au/shark-smart</a>&nbsp;</li></ul></div><div><b>Accessibility:&nbsp;</b></div><div>The following services can\nhelp you, or someone you know, access information during an emergency.&nbsp;</div><div><ul><li>To access this information in other languages, call the <a href=\"https://www.tisnational.gov.au/\" title=\"\" target=\"_blank\">Translating\nand Interpreting Service</a>&nbsp;on&nbsp;131\n450&nbsp;(freecall) and ask them to call VicEmergency Hotline.&nbsp;</li><li>If you are deaf, hard of\nhearing, or have a speech/communication impairment contact the&nbsp;<a href=\"https://www.accesshub.gov.au/\" title=\"\" target=\"_blank\">National Relay\nService</a>&nbsp;and ask\nthem to call the VicEmergency Hotline. </li></ul></div></div>","text":"ADVICE - DANGEROUS ANIMAL - Avoid the Area\nIncident Location: Bells Beach\nIssue Date: Sunday 21 June 2026, 05:25 pm\nNext Update: Monday 22 June 2026, 02:20 pm\n\nMore details at http://emergency.vic.gov.au/respond/#!/warning/42015/moreinfo\n\nThis Advice message is being issued for Bells Beach.\n\n- This replaces the Advice issued at 4:40pm. \n- To reduce the threat to people, Bells Beach and Winkipop are closed.\n- Due to a whale carcass there could be an increase in shark activity at Bells Beach and Winkipop.\n- A whale carcass can attract sharks to the area and mean they are closer to the shore than normal.\n- While it is not uncommon for sharks to be present off the Victorian coast, you should exercise additional caution in the area. \n\n\nAvoid the area. Stay informed and do not enter the water at closed beaches. \n\n","sizeFmt":null,"incidentFeatures":[{"properties":{"feedType":"incident","sourceOrg":"EMV","sourceId":"42015","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"42015","category1":"Env","category2":"Dangerous Animal","name":"Advice","location":"Bells Beach","created":"2026-06-21T17:25:38+10:00","updated":"2026-06-21T17:25:39+10:00","webHeadline":null,"sizeFmt":null}}]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DEECA","sourceId":3025685,"sourceFeed":"deeca-burns","sourceTitle":"Olinda - Road 17","id":3025685,"category1":"Planned Burn","category2":"Planned Burn","created":"2026-06-10T06:52:29.000Z","updated":"2026-06-10T06:52:29.000Z","resources":0,"size":"0.10","sizeFmt":"0.10 Ha.","url":"https://www.ffm.vic.gov.au/bushfire-fuel-and-risk-management/planned-burning-in-victoria","location":"3Km E Of Olinda"},"type":"Feature","geometry":{"type":"Point","coordinates":[145.4005558,-37.8503281]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DEECA","sourceId":3026892,"sourceFeed":"deeca-burns","sourceTitle":"Olinda Golf Course - Burn Piles","id":3026892,"category1":"Planned Burn","category2":"Planned Burn","created":"2026-06-10T06:52:01.000Z","updated":"2026-06-10T06:52:01.000Z","resources":0,"size":"0.10","sizeFmt":"0.10 Ha.","url":"https://www.ffm.vic.gov.au/bushfire-fuel-and-risk-management/planned-burning-in-victoria","location":"1Km Ne Of Olinda"},"type":"Feature","geometry":