47732881153],[146.1451824522779,-37.516962249451325],[146.14026149259536,-37.50597809227596],[146.13614161954533,-37.47764785692434],[146.16360743985797,-37.4754681629908],[146.1622341488473,-37.449306877423595],[146.18969996915996,-37.42749881465222],[146.1630352354888,-37.449942853308265],[146.1932476378318,-37.42431794398739],[146.19381984220104,-37.42204580601956],[146.19244655119033,-37.42313643951782],[146.25012477384604,-37.42095515663664],[146.30242427356816,-37.58500978089746]]]}]},"properties":{"feedType":"warning","cap":{"category":"Fire","event":"Bushfire","eventCode":"bushFire","urgency":"Expected","severity":"Minor","certainty":"Unknown","contact":"fleur.smith@parks.vic.gov.au","senderName":"Forest Fire Management Victoria","responseType":"Monitor"},"sourceOrg":"EMV","sourceId":"41693","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"41693","category1":"Advice","category2":"Fire","status":"Minor","name":"Advice","action":"Stay Informed","statewide":"N","location":"Pemburthy, Woods Point, A1 Mine Settlement, Raspberry Point, View Point, Gaffneys Creek, Jericho, Matlock","created":"2026-03-06T17:04:25+11:00","updated":"2026-03-06T17:04:24+11:00","webHeadline":null,"webBody":"<div style=\"margin-bottom:20px\">This <b>Advice</b> message is being issued for the area surround Gaffney's Creek and Wood's Point.&nbsp; There is a bushfire at&nbsp;<span title=\"warning_incident_location\" class=\"param\" contenteditable=\"false\">Mansfield-Woods Point Rd, Gaffneys Creek</span>&nbsp;that is now contained.<div><br></div><div>This Advice replaces the Advice message issued yesterday, on Thursday 5th March at 10.58am.</div></div><div style=\"font-size: 120%; font-weight: bold; margin-bottom:20px\"><ul><li>There is currently no threat to communities, but you should continue to stay informed and monitor conditions.&nbsp;</li><li>Monitor weather warnings, forecasts, and river levels through the VicEmergency website/app/hotline.&nbsp;</li></ul></div><div style=\"margin-bottom:20px\"><b>What you should do:&nbsp;</b><div><ul><li>Monitor weather conditions\nand warnings.&nbsp;</li><li>Review your fire survival plan.&nbsp;</li><li>If you do not have a plan, decide what you will\ndo if the situation changes. </li></ul></div></div><div style=\"margin-bottom:20px\"><b>Impacts in your area:&nbsp;</b><div><br></div><div><div>The following roads are closed:</div><div><ul><li>German Spur Track</li><li>Gaffney's Creek Track</li><li>Frenchman's Gap Track.</li><li>Check the VicTraffic website (traffic.transport.vic.gov.au) or call 13 11 70 for road closures.</li></ul><br>The Mansfield-Woods Point Road is now open to through traffic only.&nbsp; Please do not stop between Gaffney's Creek township and Frenchman's Gap.&nbsp; For personal safety, please do not enter any closed areas or tracks that are within the fire ground.&nbsp;&nbsp;</div><div>&nbsp;<br><ul><li>Ausnet are currently working in the area to reinstate electrical services to local communities.</li><li>Firefighters will continue to patrol this fire.</li><li>Be aware that in fire affected areas, rainfall runoff into waterways may contain debris such as ash, soil, trees and rocks.&nbsp; Heavy rainfall may increase the potential for landslides and debris across roads.&nbsp;<br></li></ul></div></div></div><div style=\"margin-bottom:20px\"><div><br></div><div>This message was issued\nby <span title=\"warning_issuing_agency\" class=\"param\" contenteditable=\"false\">Forest Fire Management Victoria</span>.</div><div><br></div><div><b>The next update is expected by </b><span title=\"warning_next_update\" class=\"param\" contenteditable=\"false\">10/03/2026 11:30 am</span><b>&nbsp;or\nas the situation changes.</b></div><div><br></div><div><div><b>Use multiple sources to stay informed:&nbsp;</b></div></div><div><ul><li><a href=\"http://emergency.vic.gov.au/respond/\" title=\"\" target=\"_blank\">www.emergency.vic.gov.au</a></li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/115001055007-What-is-the-VicEmergency-Hotline-\" title=\"\" target=\"_blank\" style=\"background-color: white;\">VicEmergency Hotline</a>&nbsp;- freecall 1800 226 226</li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/230492607-What-is-the-VicEmergency-app-\" title=\"\" target=\"_blank\" style=\"background-color: white;\">VicEmergency app</a></li><li><a href=\"https://www.facebook.com/vicemergency\" title=\"\" target=\"_blank\">\nFacebook</a> or&nbsp;<a href=\"https://twitter.com/vicemergency\" title=\"\" target=\"_blank\" style=\"background-color: white;\">Twitter</a>&nbsp;(#VicFires)</li><li>Tune in to ABC Local Radio, commercial and designated community radio stations, or Sky News TV. </li><li>Please click here to see the&nbsp;<a href=\"/https://files-em.em.vic.gov.au/public/CommNews/Fact-Sheets/23.02.2026_-_Information_for_Community_-_Woods_Point.pdf?v=202602231346\" title=\"Newsletter\" target=\"_blank\">Newsletter</a></li></ul><div><b>Accessibility:</b></div></div><div>The following services can\nhelp you, or someone you know, access information during an emergency. </div><div><ul><li>To access this information in other languages call the <a href=\"https://www.tisnational.gov.au/\" title=\"\" target=\"_blank\">Translating\nand Interpreting Service</a>&nbsp;on&nbsp;131\n450&nbsp;(freecall) and ask them to call VicEmergency Hotline.</li><li>If you are deaf, hard of\nhearing, or have a speech/communication impairment contact <a href=\"https://www.accesshub.gov.au/about-the-nrs/nrs-call-numbers-and-links\" title=\"\" target=\"_blank\">National\nRelay Service&nbsp;</a>on 1800 555 677\nand ask them to call the VicEmergency Hotline.</li></ul></div></div>","text":"ADVICE - BUSHFIRE - Stay Informed\nIncident Location: Mansfield-Woods Point Rd, Gaffneys Creek\nIssue Date: Friday 06 March 2026, 05:04 pm\nNext Update: Tuesday 10 March 2026, 11:30 am\n\nMore details at http://emergency.vic.gov.au/respond/#!/warning/41693/moreinfo\n\nThis Advice message is being issued for the area surround Gaffney's Creek and Wood's Point.  There is a bushfire at Mansfield-Woods Point Rd, Gaffneys Creek that is now contained.\n\nThis Advice replaces the Advice message issued yesterday, on Thursday 5th March at 10.58am.\n\n- There is currently no threat to communities, but you should continue to stay informed and monitor conditions. \n- Monitor weather warnings, forecasts, and river levels through the VicEmergency website/app/hotline. \n\n\n","sizeFmt":null,"incidentFeatures":[{"properties":{"feedType":"incident","sourceOrg":"EMV","sourceId":"41693","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"41693","category1":"Fire","category2":"Bushfire","name":"Advice","location":"Mansfield-Woods Point Rd, Gaffneys Creek","created":"2026-03-06T17:04:25+11:00","updated":"2026-03-06T17:04:24+11:00","webHeadline":null,"sizeFmt":null}}]}},{"type":"Feature","geometry":{"type":"GeometryCollection","geometries":[{"type":"Point","coordinates":[143.48598770242108,-38.50170838102764]},{"type":"Polygon","coordinates":[[[143.4059935007608,-38.46222731041315],[143.43963913064852,-38.44071786212866],[143.50075058083993,-38.4455580470197],[143.56392196755635,-38.477817650699244],[143.57010177713144,-38.51973356232801],[143.54881576638488,-38.55088599074463],[143.50349716287033,-38.55840352119509],[143.44032577615386,-38.56269889992663],[143.40187362771073,-38.53907114041147],[143.4046202097501,-38.50630163126035],[143.4059935007608,-38.46222731041315]]]}]},"properties":{"feedType":"warning","cap":{"category":"Fire","event":"Bushfire","eventCode":"bushFire","urgency":"Unknown","severity":"Unknown","certainty":"Observed","contact":"birgitte.hutchens@delwp.vic.gov.au","senderName":"Forest Fire Management Victoria","responseType":"None"},"sourceOrg":"EMV","sourceId":"41700","sourceFeed":"cop-cap","sourceTitle":"Community Information","id":"41700","category1":"Community Update","category2":"Fire","status":"Unknown","name":"Community Information","action":"Stay Informed","statewide":"N","location":"between the townships of  Irrewillipe, Kawarren, Lovat, Wimba, Charleys Creek, Carlisle River and covers the township of Gellibrand","created":"2026-03-08T14:38:34+11:00","updated":"2026-03-08T14:38:57+11:00","webHeadline":null,"webBody":"<div style=\"margin-bottom:20px\">This <b>Community Information</b>&nbsp;message is being issued for <span title=\"warning_locality\" class=\"param\" contenteditable=\"false\">between the townships of  Irrewillipe, Kawarren, Lovat, Wimba, Charleys Creek, Carlisle River and covers the township of Gellibrand</span>.&nbsp;<div><div><ul><li>There is a bushfire at&nbsp;<span title=\"warning_incident_location\" class=\"param\" contenteditable=\"false\">Carlisle River</span>&nbsp;that is&nbsp;<span class=\"editable editable-click editable-unsaved\" data-type=\"select\" data-emptytext=\"[status]\" data-value=\"1\" contenteditable=\"false\" style=\"display: inline;\" data-source=\"{&quot;0&quot;:&quot;not yet under control&quot;,&quot;1&quot;:&quot;under control&quot;}\" data-original-title=\"\" title=\"\">under control</span>.</li><li>This Community Information replaces the message issued on 4 March 2026.</li><li>Firefighters\nare currently patrolling this fire.</li><li>Please observe all track closures.&nbsp;</li></ul></div></div></div><div style=\"font-size: 120%; font-weight: bold; margin-bottom:20px\">There is currently no threat to the community however be aware of crews and heavy machinery working to rehabilitate affected tracks and stabilising areas of the fire ground.</div><div style=\"margin-bottom:20px\">This message was issued\nby <span title=\"warning_issuing_agency\" class=\"param\" contenteditable=\"false\">Forest Fire Management Victoria</span>.<div><br></div><div><br></div><div><b>Use multiple sources to stay informed:&nbsp;</b></div><div><ul><li><a href=\"http://emergency.vic.gov.au/respond/\" title=\"\" target=\"_blank\">www.emergency.vic.gov.au</a></li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/115001055007-What-is-the-VicEmergency-Hotline-\" title=\"\" target=\"_blank\">\n VicEmergency Hotline</a>&nbsp;- freecall 1800 226 226</li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/230492607-What-is-the-VicEmergency-app-\" title=\"\" target=\"_blank\" style=\"background-color: white;\">VicEmergency app</a></li><li><a href=\"https://www.facebook.com/vicemergency\" title=\"\" target=\"_blank\">\nFacebook</a> or&nbsp;<a href=\"https://twitter.com/vicemergency\" title=\"\" target=\"_blank\" style=\"background-color: white;\">Twitter</a>&nbsp;(#vicfires).</li><li>Tune in to ABC Local Radio, commercial and designated community radio stations, or Sky News TV. </li></ul><div><b>Accessibility: </b></div></div><div>The following services can\nhelp you, or someone you know, access information during an emergency. </div><div><ul><li>\n To access this information\n     in other languages call the <a href=\"https://www.tisnational.gov.au/\" title=\"Translating and Interpreting Service\" target=\"_blank\">Translating and Interpreting Service</a>&nbsp;on&nbsp;131 450&nbsp;(freecall) and ask\n     them to call VicEmergency Hotline. &nbsp;\n </li><li>If you are deaf, hard of\nhearing, or have a speech/communication impairment contact <a href=\"https://www.accesshub.gov.au/about-the-nrs/nrs-call-numbers-and-links\" title=\"\" target=\"_blank\">National Relay Service&nbsp;</a>for assistance\nand ask them to call the VicEmergency Hotline.&nbsp; </li></ul></div></div>","text":"COMMUNITY INFORMATION - BUSHFIRE - Stay Informed\nIncident Location: Carlisle River\nIssue Date: Sunday 08 March 2026, 02:38 pm\nNext Update: Friday 13 March 2026, 02:40 pm\n\nMore details at http://emergency.vic.gov.au/respond/#!/warning/41700/moreinfo\n\nThis Community Information message is being issued for between the townships of  Irrewillipe, Kawarren, Lovat, Wimba, Charleys Creek, Carlisle River and covers the township of Gellibrand. \n- There is a bushfire at Carlisle River that is under control.\n- This Community Information replaces the message issued on 4 March 2026.\n- Firefighters are currently patrolling this fire.\n- Please observe all track closures. \n\n\nThere is currently no threat to the community however be aware of crews and heavy machinery working to rehabilitate affected tracks and stabilising areas of the fire ground.\n\n","sizeFmt":null,"incidentFeatures":[{"properties":{"feedType":"incident","sourceOrg":"EMV","sourceId":"41700","sourceFeed":"cop-cap","sourceTitle":"Community Information","id":"41700","category1":"Fire","category2":"Bushfire","name":"Community Information","location":"Carlisle River","created":"2026-03-08T14:38:34+11:00","updated":"2026-03-08T14:38:57+11:00","webHeadline":null,"sizeFmt":null}}]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DELWP","sourceId":3001817,"sourceFeed":"delwp-burns","sourceTitle":"Berrybank - Lower Darlington Road","id":3001817,"category1":"Planned Burn","category2":"Planned Burn","created":"2026-03-06T02:55:13.000Z","updated":"2026-03-06T02:55:13.000Z","resources":0,"size":"52.73","sizeFmt":"52.73 Ha.","url":"https://www.ffm.vic.gov.au/bushfire-fuel-and-risk-management/planned-burning-in-victoria","location":"None"},"type":"Feature","geometry":{"type":"Point","coordinates":[143.4548576,-38.0201789]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DELWP","sourceId":3007586,"sourceFeed":"delwp-burns","sourceTitle":"Darlington - Darlington-Terang Road","id":3007586,"category1":"Planned Burn","category2":"Planned Burn","created":"2026-03-08T02:36:26.000Z","updated":"2026-03-08T02:36:26.000Z","resources":0,"size":"23.21","sizeFmt":"23.21 Ha.","url":"https://www.ffm.vic.gov.au/bushfire-fuel-and-risk-management/planned-burning-in-victoria","location":"3Km Sw Of Darlington"},"type":"Feature","geometry":{"type":"Point","coordinates":[143.0034561,-38.0242983]}},{"properties":{"status":"Patrolled","fee