67129655814039],[144.93759042828677,-37.670617179562555],[144.93836290448476,-37.66973397811231],[144.93922121136646,-37.66789960305435],[144.94025117963346,-37.66620106720353],[144.94110948651513,-37.66280387889078],[144.9442852219908,-37.66178469207851],[144.94213945477316,-37.65582216886514]]]}]},"properties":{"feedType":"warning","cap":{"category":"Other","event":"Water quality","eventCode":"water","urgency":"Unknown","severity":"Unknown","certainty":"Observed","contact":"lily.watson-jones@justice.vic.gov.au","senderName":"Environment Protection Authority","responseType":"None"},"sourceOrg":"EMV","sourceId":"41996","sourceFeed":"cop-cap","sourceTitle":"Community Information","id":"41996","category1":"Community Update","category2":"Other","status":"Unknown","name":"Community Information","action":"Stay Informed","statewide":"N","location":"Dallas, Broadmeadows, Campbellfield, Coolaroo","created":"2026-06-11T16:14:15+10:00","updated":"2026-06-11T16:14:15+10:00","webHeadline":null,"webBody":"<div style=\"margin-bottom:20px\">This message is\nbeing issued for water quality at <span class=\"editable editable-click editable-unsaved\" data-type=\"text\" data-emptytext=\"[Location]\" data-value=\"Merlynston Creek\" contenteditable=\"false\" style=\"display: inline;\" data-original-title=\"\" title=\"\">Merlynston Creek</span>. <div><br></div><div><ul><li>\n Water\n     used to extinguish a factory fire on Nathan Drive, Campbellfield has\n     entered Merlynston Creek. The water may contain chemicals and heavy metals\n     that may pose risks to human and animal health.&nbsp;\n </li><li>\n Do not\n     enter or touch the water in Merlynston Creek between National Boulevard,\n     Campbellfield and Jack Roper Reserve.\n </li><li>\n Keep\n     pets away from the creek water and lake.&nbsp;&nbsp;</li><li>Do not\n     consume fish from Jack Roper Reserve.&nbsp;\n </li><br></ul></div></div><div style=\"font-size: 120%; font-weight: bold; margin-bottom:20px\">You should\navoid contact with the water in Merlynston Creek, do not allow your pets\nto swim in or drink the water.&nbsp; </div><div style=\"margin-bottom:20px\">This message was issued by <span title=\"warning_issuing_agency\" class=\"param\" contenteditable=\"false\">Environment Protection Authority</span>.<div><br></div><div><b helvetica=\"\" neue\",=\"\" helvetica,=\"\" arial,=\"\" sans-serif;=\"\" font-size:=\"\" 14px;\"=\"\">Unless the situation changes, this will be the last message issued for this incident.</b></div><div><div><br></div><div><b>Use multiple sources to stay informed:</b></div><div><ul><li>For updates on water quality, visit: <a href=\"https://www.epa.vic.gov.au/check-air-and-water-quality\" title=\"\" target=\"_blank\">Check air and water quality </a></li><li><a href=\"https://www.emergency.vic.gov.au/respond/\" title=\"\" target=\"_blank\">www.emergency.vic.gov.au</a>.</li><li>VicEmergency Hotline&nbsp;- freecall 1800 226 226.</li><li><a href=\"https://support.emergency.vic.gov.au/hc/en-gb/articles/230492607-What-is-the-VicEmergency-app\" title=\"\" target=\"_blank\">VicEmergency app</a>.</li><li><a href=\"https://www.facebook.com/vicemergency/\" title=\"\" target=\"_blank\">Facebook&nbsp;</a>or&nbsp;<a href=\"https://x.com/vicemergency\" title=\"\" target=\"_blank\">Twitter</a>.</li><li>ABC Local Radio, commercial and designated community radio stations, or Sky News TV.</li></ul><div><br></div><b>Accessibility:</b></div><div>The following services can help you, or someone you know, access information during an emergency.</div><div><ul><li>For information in other languages call the&nbsp;Translating and Interpreting Service&nbsp;on&nbsp;131 450&nbsp;(freecall) and ask them to call the VicEmergency Hotline.</li><li>If you are deaf, hard of hearing, or have a speech/communication impairment contact the National Relay Service and ask them to call the VicEmergency Hotline.&nbsp;</li></ul></div></div></div>","text":"COMMUNITY INFORMATION - WATER QUALITY - Stay Informed\nIncident Location: Nathan Dr, Campbellfield\nIssue Date: Thursday 11 June 2026, 04:14 pm\nNext Update: Saturday 13 June 2026, 04:20 pm\n\nMore details at http://emergency.vic.gov.au/respond/#!/warning/41996/moreinfo\n\nThis message is being issued for water quality at Merlynston Creek. \n\n-   Water      used to extinguish a factory fire on Nathan Drive, Campbellfield has      entered Merlynston Creek. The water may contain chemicals and heavy metals      that may pose risks to human and animal health.   \n-   Do not      enter or touch the water in Merlynston Creek between National Boulevard,      Campbellfield and Jack Roper Reserve.  \n-   Keep      pets away from the creek water and lake.  \n- Do not      consume fish from Jack Roper Reserve.   \n\n\n\nYou should avoid contact with the water in Merlynston Creek, do not allow your pets to swim in or drink the water.  \n\n","sizeFmt":null,"incidentFeatures":[{"properties":{"feedType":"incident","sourceOrg":"EMV","sourceId":"41996","sourceFeed":"cop-cap","sourceTitle":"Community Information","id":"41996","category1":"Other","category2":"Water quality","name":"Community Information","location":"Nathan Dr, Campbellfield","created":"2026-06-11T16:14:15+10:00","updated":"2026-06-11T16:14:15+10:00","webHeadline":null,"sizeFmt":null}}]}},{"properties":{"status":"Controlled","feedType":"incident","sourceOrg":"SA/CFS","sourceId":"1708182","sourceFeed":"cfs-incident","sourceTitle":"Grant Avenue, Moorak","id":"1708182","category1":"Fire","category2":"Planned Burn","name":"Grant Avenue, Moorak","created":"2026-06-08T22:26:00.000Z","updated":"2026-06-08T22:26:00.000Z","url":"http://www.cfs.sa.gov.au/site/warnings_and_incidents.jsp","location":"Grant Avenue, Moorak"},"type":"Feature","geometry":{"type":"Point","coordinates":[140.75853458686,-37.8470399195199]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DEECA","sourceId":3019067,"sourceFeed":"deeca-burns","sourceTitle":"Anglesea - Anglese