{"type":"FeatureCollection","features":[{"type":"Feature","geometry":{"type":"GeometryCollection","geometries":[{"type":"Point","coordinates":[144.58817156292696,-37.70542990046714]},{"type":"Polygon","coordinates":[[[144.57765730359267,-37.69405559772281],[144.60340651013297,-37.696228900456646],[144.60005911328093,-37.71680420321146],[144.57293661572095,-37.7144278098755],[144.57302244641363,-37.71273033939824],[144.57765730359267,-37.69405559772281]]]}]},"properties":{"feedType":"warning","cap":{"category":"Fire","event":"Grass Fire","eventCode":"grassFire","urgency":"Expected","severity":"Minor","certainty":"Unknown","contact":"luke.kneebone@frv.vic.gov.au","senderName":"Country Fire Authority","responseType":"Monitor"},"sourceOrg":"EMV","sourceId":"41955","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"41955","category1":"Advice","category2":"Fire","status":"Minor","name":"Advice","action":"Stay Informed","statewide":"N","location":"Cobblebank","created":"2026-05-24T08:28:07+10:00","updated":"2026-05-24T08:28:08+10:00","webHeadline":null,"webBody":"<div style=\"margin-bottom:20px\">This <b>Advice</b> message is being issued for&nbsp;<span title=\"warning_locality\" class=\"param\" contenteditable=\"false\">Cobblebank</span>.<div><div><ul><li>There is a mulch fire at <span title=\"warning_incident_location\" class=\"param\" contenteditable=\"false\">Abey Rd, Cobblebank</span>.</li></ul></div></div></div><div style=\"font-size: 120%; font-weight: bold; margin-bottom:20px\">There is currently no threat to you, but you should stay informed and\nmonitor conditions. </div><div style=\"margin-bottom:20px\"><b>What you should do:</b><div><ul><li>Keep the roads clear so emergency\nservices can respond.</li></ul></div></div><div style=\"margin-bottom:20px\"><div><b>Impacts in your area:&nbsp;</b></div><div><ul><li>Smoke may be visible from nearby communities and roads.&nbsp;</li><li>Crews will be working in the areas</li></ul></div></div><div style=\"margin-bottom:20px\">This message was issued by <span title=\"warning_issuing_agency\" class=\"param\" contenteditable=\"false\">Country Fire Authority</span>.&nbsp;<div><br></div><div><b>The next update is expected by <span title=\"warning_next_update\" class=\"param\" contenteditable=\"false\">24/05/2026 12:00 pm</span>&nbsp;or as the situation changes.</b></div><div><br></div><div><div><b>Use multiple sources to stay informed:&nbsp;</b></div></div><div><ul><li><a href=\"http://emergency.vic.gov.au/respond/\" title=\"\" target=\"_blank\">www.emergency.vic.gov.au</a></li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/115001055007-What-is-the-VicEmergency-Hotline-\" title=\"\" target=\"_blank\" style=\"background-color: white;\">VicEmergency Hotline</a>&nbsp;-\nfreecall 1800 226 226</li><li><a href=\"https://vicemergency.zendesk.com/hc/en-gb/articles/230492607-What-is-the-VicEmergency-app-\" title=\"\" target=\"_blank\" style=\"background-color: white;\">VicEmergency app</a></li><li><a href=\"https://www.facebook.com/vicemergency\" title=\"\" target=\"_blank\"> Facebook</a> or&nbsp;<a href=\"https://twitter.com/vicemergency\" title=\"\" target=\"_blank\" style=\"background-color: white;\">Twitter</a>&nbsp;(#vicfires)</li><li>Tune in to ABC Local Radio, commercial and designated community radio stations, or Sky News TV. </li></ul><div><b>Accessibility:&nbsp;</b></div></div><div>The following services can\nhelp you, or someone you know, access information during an emergency. </div><div><ul><li>To access this information in other languages call the <a href=\"https://www.tisnational.gov.au/\" title=\"\" target=\"_blank\">Translating\nand Interpreting Service</a>&nbsp;on&nbsp;131\n450&nbsp;(freecall) and ask them to call VicEmergency Hotline.</li><li>If you are deaf, hard of\nhearing, or have a speech/communication impairment contact <a href=\"https://www.accesshub.gov.au/about-the-nrs/nrs-call-numbers-and-links\" title=\"\" target=\"_blank\">National\nRelay Service</a>&nbsp;for assistance\nand ask them to call the VicEmergency Hotline.&nbsp; </li></ul></div></div>","text":"ADVICE - GRASS FIRE - Stay Informed\nIncident Location: Abey Rd, Cobblebank\nIssue Date: Sunday 24 May 2026, 08:28 am\nNext Update: Sunday 24 May 2026, 12:00 pm\n\nMore details at http://emergency.vic.gov.au/respond/#!/warning/41955/moreinfo\n\nThis Advice message is being issued for Cobblebank.\n- There is a mulch fire at Abey Rd, Cobblebank.\n\n\nThere is currently no threat to you, but you should stay informed and monitor conditions. \n\n","sizeFmt":null,"incidentFeatures":[{"properties":{"feedType":"incident","sourceOrg":"EMV","sourceId":"41955","sourceFeed":"cop-cap","sourceTitle":"Advice","id":"41955","category1":"Fire","category2":"Grass Fire","name":"Advice","location":"Abey Rd, Cobblebank","created":"2026-05-24T08:28:07+10:00","updated":"2026-05-24T08:28:08+10:00","webHeadline":null,"sizeFmt":null}}]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DEECA","sourceId":840417,"sourceFeed":"deeca-burns","sourceTitle":"Anglesea - Hurst Road","id":840417,"category1":"Planned Burn","category2":"Planned Burn","created":"2026-05-16T01:58:11.000Z","updated":"2026-05-16T01:58:11.000Z","resources":0,"size":"323.99","sizeFmt":"323.99 Ha.","url":"https://www.ffm.vic.gov.au/bushfire-fuel-and-risk-management/planned-burning-in-victoria","location":"3Km Ne From Anglesea"},"type":"Feature","geometry":{"type":"Point","coordinates":[144.218,-38.3823]}},{"properties":{"status":"Patrolled","feedType":"incident","sourceOrg":"VIC/DEECA","sourceId":934915,"sourceFeed":"deeca-burns","sourceTitle":"Parkers Corner - Finns Track","id":934915,"category1":"Planned Burn","category2":"Planned Burn","created":"2026-05-02T08:00:46.000Z","updated":"2026-05-02T08:00:46.000Z","resources":0,"size":"74.15","sizeFmt":"74.15 Ha.","url":"https://www.ffm.vic.gov.au/bushfire-fuel-and-risk-management/planned-burning-in-victoria","location":"2Km Nw Of Rawson"},"type":"